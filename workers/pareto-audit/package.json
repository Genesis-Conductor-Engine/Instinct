{
  "name": "pareto-audit",
  "version": "0.1.0",
  "description": "Cloudflare Worker for pareto-audit pipeline filtering",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 execute pareto-audit --file=./src/schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  },
  "keywords": [
    "cloudflare-workers",
    "pareto",
    "genesis-conductor"
  ]
}
