# Blackhorse-ʞGraph API Environment Configuration

# Server
NODE_ENV=production
PORT=8080
LOG_LEVEL=info
FRONTEND_URL=http://localhost:5173

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=blackhorse_kgraph
PG_USER=postgres
PG_PASSWORD=your_secure_password_here

# Redis (for Socket.io scaling and caching)
REDIS_URL=redis://localhost:6379

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# Security
JWT_SECRET=your_jwt_secret_here_min_32_chars
API_RATE_LIMIT=100

# Blackhorse Integration
BLACKHORSE_AGENT_URL=http://localhost:8081
HONEYPOT_NETWORK_PREFIX=172.20.0
PHYSICAL_TEST_MODE=false

# ʞ Graph Configuration
KG_EXTRACTION_BATCH_SIZE=5
KG_CONFIDENCE_THRESHOLD=0.7
KG_MAX_NODES_PER_CONVERSATION=100

# Token Optimization (Claude Modality Router)
DEFAULT_MODALITY=Haiku
AUTO_ESCALATION_ENABLED=true
THERMAL_LIMIT_MS=2000
COST_BUDGET_PER_SESSION=0.50

# Monitoring
METRICS_ENABLED=true
PROMETHEUS_PORT=9090
